# --- Sanity ---
# Create a Sanity project at https://www.sanity.io/manage, then fill in:
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-05-01
# Token with write access (used by the CSV importer and inquiry submissions).
# Generate at https://www.sanity.io/manage > API > Tokens (Editor or Write role).
SANITY_API_WRITE_TOKEN=

# --- Resend ---
# https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender (must match a domain verified in Resend).
RESEND_FROM_EMAIL=Soho Architects <hello@example.com>
# Where inquiry submissions are delivered.
INQUIRY_RECIPIENT_EMAIL=studio@example.com

# --- Site ---
# Do NOT set NEXT_PUBLIC_SITE_URL here. Next.js inlines NEXT_PUBLIC_* at
# build time, so any value would bake into the deployed bundle and
# override the wrangler.jsonc runtime var. The fallback in lib/seo.ts +
# app/sitemap.ts + app/robots.ts + app/layout.tsx resolves to the
# production URL when this is unset.
